@model ErrorViewModel
@{
    ViewData["Title"] = "Ошибка";
}

<h1 class="text-danger">Ошибка.</h1>
<h2 class="text-danger">Произошла ошибка при обработке запроса.</h2>

@if (Model.ShowRequestId)
{
    <p>
        <strong>ID запроса:</strong> <code>@Model.RequestId</code>
    </p>
}

<h3>Режим разработки</h3>
<p>
    В среде <strong>Development</strong> отображается более подробная информация об ошибке.
</p>
<p>
    <strong>Не включайте Development в опубликованном приложении.</strong>
    Это может показывать пользователям чувствительные данные из исключений.
    Для локальной отладки задайте переменную среды <strong>ASPNETCORE_ENVIRONMENT</strong> = <strong>Development</strong>
    и перезапустите приложение.
</p>
